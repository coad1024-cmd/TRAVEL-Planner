{
  "name": "travel-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "acceptance": "node packages/orchestrator/dist/tests/acceptance.js",
    "cli": "node packages/orchestrator/dist/cli.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "rag:seed": "python3 packages/rag-pipeline/src/ingest.py --seed",
    "rag:serve": "uvicorn packages.rag_pipeline.src.retrieval_service:app --host 0.0.0.0 --port 8001 --reload",
    "webhook": "node packages/webhook-ingress/dist/index.js",
    "scheduler": "node packages/scheduler/dist/index.js"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/express": "^4.17.25",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^4.1.4",
    "express": "^4.22.1",
    "ioredis": "^5.10.1",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
