# Amadeus (flights)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Duffel (flights fallback)
DUFFEL_API_KEY=

# Google Maps (routing, places, geocoding)
GOOGLE_MAPS_KEY=

# OpenWeatherMap
OPENWEATHERMAP_KEY=

# Open Exchange Rates (currency)
OPEN_EXCHANGE_RATES_KEY=

# Booking.com via RapidAPI (accommodation)
BOOKING_RAPIDAPI_KEY=

# Foursquare Places
FOURSQUARE_KEY=

# OpenAI (embeddings + metadata generation)
OPENAI_API_KEY=

# Twilio (SMS)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (India payments)
RAZORPAY_KEY=
RAZORPAY_SECRET=

# FlightAware AeroAPI (real-time flight status)
FLIGHTAWARE_API_KEY=

# Mindee OCR (receipt scanning)
MINDEE_API_KEY=

# Firebase Cloud Messaging (push notifications)
FIREBASE_CONFIG=

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Redis (event bus)
REDIS_URL=redis://localhost:6379

# PostgreSQL (state store)
DATABASE_URL=postgresql://localhost:5432/travel_system

# RAG Pipeline (ChromaDB + retrieval service)
CHROMA_PERSIST_PATH=./data/chroma
RAG_SERVICE_URL=http://localhost:8001

# Anthropic (Claude — for agent LLM calls)
ANTHROPIC_API_KEY=

# Safety & Emergency (Real-time integrations)
# Set to 'true' to override demo overrides (which default to high-fidelity mock data)
ENABLE_REAL_ADVISORY=false
ENABLE_REAL_EMERGENCY=false

# Application
NODE_ENV=development
PORT=3000
WEBHOOK_PORT=3001
LOG_LEVEL=info
